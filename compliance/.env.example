# The Compliance Agent runs entirely on a local Ollama model — no API key needed.
# Just Neo4j credentials (same instance as ingestion/ and rag/):

NEO4J_URI=neo4j+s://your-instance-id.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# The /ask endpoint (via ../rag/) still needs Gemini — copy that value in too
# if you're running api.py, not just the Compliance Agent standalone:
GEMINI_API_KEY=your_gemini_api_key_here
